{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "AEGIS-SIGHT API performance metrics: latency percentiles, request rate, error rate, DB query time, and Redis cache hit ratio.",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "API Response Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"aegis-sight-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"aegis-sight-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"aegis-sight-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"aegis-sight-api\"}[5m]))",
          "legendFormat": "Total req/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"aegis-sight-api\"}[5m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"aegis-sight-api\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"aegis-sight-api\"}[5m])) * 100",
          "legendFormat": "5xx Error Rate",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"aegis-sight-api\", status=~\"4..\"}[5m])) / sum(rate(http_requests_total{job=\"aegis-sight-api\"}[5m])) * 100",
          "legendFormat": "4xx Error Rate",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Response Time by Endpoint (p95)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"aegis-sight-api\"}[5m])) by (le, handler)) * 1000",
          "legendFormat": "{{handler}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "le": true },
            "renameByName": { "handler": "Endpoint", "Value": "p95 (ms)" }
          }
        }
      ]
    },
    {
      "title": "Database Query Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(db_query_duration_seconds_bucket{job=\"aegis-sight-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "DB p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket{job=\"aegis-sight-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "DB p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(db_query_duration_seconds_bucket{job=\"aegis-sight-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "DB p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Redis Cache Hit Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(redis_cache_hits_total{job=\"aegis-sight-api\"}[5m])) / (sum(rate(redis_cache_hits_total{job=\"aegis-sight-api\"}[5m])) + sum(rate(redis_cache_misses_total{job=\"aegis-sight-api\"}[5m]))) * 100",
          "legendFormat": "Cache Hit Rate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active DB Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 25 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "db_pool_connections_active{job=\"aegis-sight-api\"}",
          "legendFormat": "Active",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Duration Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 24 },
      "datasource": "Prometheus",
      "options": {
        "calculate": false,
        "yAxis": { "unit": "ms" }
      },
      "targets": [
        {
          "expr": "sum(increase(http_request_duration_seconds_bucket{job=\"aegis-sight-api\"}[1m])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["aegis-sight", "api", "performance"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "AEGIS-SIGHT API Performance",
  "uid": "aegis-api-perf",
  "version": 1
}
