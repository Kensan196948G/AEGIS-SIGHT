{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "CPU使用率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU Usage %"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } }
      }
    },
    {
      "title": "メモリ使用率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "Memory Usage %"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } }
      }
    },
    {
      "title": "ディスク使用率",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "targets": [{
        "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100",
        "legendFormat": "Disk Usage %"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } }
      }
    },
    {
      "title": "ネットワーク受信",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "targets": [{
        "expr": "irate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m])",
        "legendFormat": "{{ device }} RX"
      }],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "title": "ネットワーク送信",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "targets": [{
        "expr": "irate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m])",
        "legendFormat": "{{ device }} TX"
      }],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "title": "システム稼働時間",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 14 },
      "targets": [{
        "expr": "node_time_seconds - node_boot_time_seconds",
        "legendFormat": "Uptime"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "ロードアベレージ (1m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 14 },
      "targets": [{
        "expr": "node_load1",
        "legendFormat": "Load 1m"
      }],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 4 }, { "color": "red", "value": 8 }] } }
      }
    },
    {
      "title": "ファイルディスクリプタ使用率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 14 },
      "targets": [{
        "expr": "(node_filefd_allocated / node_filefd_maximum) * 100",
        "legendFormat": "FD Usage %"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] } }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["aegis-sight", "node-exporter", "infrastructure"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "AEGIS-SIGHT ホストメトリクス (Node Exporter)",
  "uid": "aegis-node-exporter",
  "version": 1
}
