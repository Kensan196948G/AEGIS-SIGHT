# ===========================================================================
# AEGIS-SIGHT -- Staging Environment Variables
# ===========================================================================

# ---- Application ----------------------------------------------------------
APP_NAME=AEGIS-SIGHT
DEBUG=false
LOG_LEVEL=INFO

# ---- API (FastAPI) --------------------------------------------------------
API_PORT=8000

# ---- Database (PostgreSQL 16) ---------------------------------------------
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_staging
POSTGRES_DB=aegis_sight_staging
DATABASE_URL=postgresql+asyncpg://aegis:aegis_staging@db:5432/aegis_sight_staging

# ---- Redis (Celery broker + cache) ----------------------------------------
REDIS_URL=redis://redis:6379/0

# ---- Security / JWT -------------------------------------------------------
SECRET_KEY=staging-secret-key-change-me
ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- CORS -----------------------------------------------------------------
CORS_ORIGINS=["https://staging.your-domain.com","http://localhost:3000"]

# ---- Frontend (Next.js) ---------------------------------------------------
NEXT_PUBLIC_API_URL=https://staging.your-domain.com/api
NODE_ENV=production

# ---- Celery ---------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- Observability --------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=admin_staging
GF_SERVER_ROOT_URL=https://staging.your-domain.com/grafana
PROMETHEUS_RETENTION=15d
