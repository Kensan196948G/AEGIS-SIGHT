# AEGIS-SIGHT API Environment Configuration

# Application
APP_NAME=AEGIS-SIGHT API
APP_VERSION=0.1.0
DEBUG=false

# Database (PostgreSQL 16 + asyncpg)
DATABASE_URL=postgresql+asyncpg://aegis:aegis@localhost:5432/aegis_sight

# Redis (Celery broker + cache)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated in env, parsed as JSON list by pydantic-settings)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
