# ===========================================================================
# AEGIS-SIGHT -- Environment Variables Template
# ===========================================================================
# Copy to .env and adjust values for your environment.
# ===========================================================================

# ---- Application ----------------------------------------------------------
APP_NAME=AEGIS-SIGHT
DEBUG=false

# ---- API (FastAPI) --------------------------------------------------------
API_PORT=8000

# ---- Database (PostgreSQL 16) ---------------------------------------------
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_dev
POSTGRES_DB=aegis_sight
DATABASE_URL=postgresql+asyncpg://aegis:aegis_dev@localhost:5432/aegis_sight

# ---- Redis (Celery broker + cache) ----------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---- Security / JWT -------------------------------------------------------
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- CORS -----------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ---- Frontend (Next.js) ---------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Celery ---------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---- Observability --------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_RETENTION=15d
